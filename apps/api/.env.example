# ---- apps/api environment ----
# Copy to .env and fill real values. NEVER commit .env.

# App
NODE_ENV=development
PORT=3001
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000

# Database (Neon Postgres) — get from Neon dashboard, "Connection string"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Cache / rate-limit store (Upstash Redis) — "redis://..." from Upstash
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# Auth
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost

# Email OTP (Resend) — Phase 1. Leave blank in dev to console.log the OTP.
RESEND_API_KEY=
OTP_FROM_EMAIL="NO CURFEW <login@nocurfew.example>"

# Payments (Razorpay) — Phase 4
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Image storage (Cloudflare R2) — Phase 5
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
